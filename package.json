{
	"name": "react-forge",
	"version": "1.0.0",
	"type": "module",
	"main": "index.js",
	"description": "A modern CLI tool for scaffolding production-ready React applications.",
	"scripts": {
		"dev": "tsx bin/index.ts",
		"build": "tsc",
		"lint": "biome check .",
		"format": "biome format . --write",
		"typecheck": "tsc --noEmit",
		"test": "echo \"No tests specified yet\"",
		"prepare": "husky",
		"release": "changeset",
		"version-packages": "changeset version",
		"publish-packages": "changeset publish"
	},
	"lint-staged": {
		"*.{ts,js,json,md,yml,yaml}": [
			"biome check --write"
		]
	},
	"bin": {
		"react-forge": "./dist/bin/index.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JessicaBassil/react-forge.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/JessicaBassil/react-forge/issues"
	},
	"homepage": "https://github.com/JessicaBassil/react-forge#readme",
	"dependencies": {
		"@clack/prompts": "^1.3.0",
		"fs-extra": "^11.3.5",
		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.31.0",
		"@commitlint/cli": "^21.0.0",
		"@commitlint/config-conventional": "^21.0.0",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^25.6.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
