{
	"name": "react-forged",
	"version": "0.1.2",
	"type": "module",
	"description": "A modern CLI tool for scaffolding production-ready React applications.",
	"scripts": {
		"dev": "tsx bin/index.ts",
		"build": "tsc",
		"lint": "biome check .",
		"format": "biome format . --write",
		"typecheck": "tsc --noEmit",
		"test": "echo \"No tests specified yet\"",
		"prepare": "husky",
		"release": "changeset",
		"version-packages": "changeset version",
		"publish-packages": "changeset publish"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"templates",
		"README.md",
		"LICENSE"
	],
	"keywords": [
		"react",
		"vite",
		"scaffold",
		"cli",
		"template",
		"typescript"
	],
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json}": [
			"biome check --write"
		]
	},
	"bin": {
		"react-forged": "./dist/bin/index.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JessicaBassil/react-forged.git"
	},
	"author": "",
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"bugs": {
		"url": "https://github.com/JessicaBassil/react-forged/issues"
	},
	"homepage": "https://github.com/JessicaBassil/react-forged#readme",
	"dependencies": {
		"@clack/prompts": "^1.3.0",
		"boxen": "^8.0.1",
		"fs-extra": "^11.3.5",
		"ora": "^9.4.0",
		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.31.0",
		"@commitlint/cli": "^21.0.0",
		"@commitlint/config-conventional": "^21.0.0",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^25.6.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
