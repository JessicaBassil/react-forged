{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",

	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false
	},

	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},

	"files": {
		"ignoreUnknown": false,
		"includes": ["src/**", "*.json", "*.ts", "*.tsx", "!dist", "!node_modules"]
	},

	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,

			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "warn"
			},

			"style": {
				"useImportType": "warn",
				"useTemplate": "warn",
				"noNestedTernary": "warn"
			},

			"suspicious": {
				"noConsole": "warn",
				"noDebugger": "error",
				"noArrayIndexKey": "warn",
				"noExplicitAny": "error"
			},

			"complexity": {
				"noForEach": "off",
				"noStaticOnlyClass": "warn",
				"noExcessiveCognitiveComplexity": "warn",
				"noExcessiveLinesPerFunction": "error",
				"noExcessiveNestedTestSuites": "error",
				"useMaxParams": "error"
			},
			"nursery": {
				"noFloatingPromises": "error"
			},
			"a11y": {
				"noInteractiveElementToNoninteractiveRole": "error",
				"noNoninteractiveElementInteractions": "error"
			}
		}
	},

	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all",
			"arrowParentheses": "always"
		}
	},

	"json": {
		"formatter": {
			"enabled": true
		}
	},

	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},

	"overrides": [
		{
			"includes": ["scripts/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": ["src/app/error-boundary.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		}
	]
}
